rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email']) 
        && data.uid == request.auth.uid
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 256;
    }

    function isValidConversation(data) {
      return data.keys().hasAll(['userId', 'title'])
        && data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 200;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['role', 'content'])
        && data.role in ['user', 'partner']
        && data.content is string && data.content.size() <= 10000
        && (!data.keys().contains('order') || data.order is int)
        && (!data.keys().contains('createdAt') || data.createdAt is timestamp)
        && (!data.keys().contains('analysis') || data.analysis is map);
    }

    // Routes
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'traitProfile', 'settings']);

      match /conversations/{conversationId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidConversation(incoming()) && isValidId(conversationId);
        allow update: if isOwner(userId) // && isValidConversation(incoming()) // Basic owner check sufficient for generic updates if schema valid
          && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'status', 'lastMessageAt']);
        allow delete: if isOwner(userId);

        match /messages/{messageId} {
          allow list, get: if isOwner(userId);
          allow create: if isOwner(userId) && isValidMessage(incoming()) && isValidId(messageId);
          allow update: if isOwner(userId) && isValidMessage(incoming())
            && incoming().diff(existing()).affectedKeys().hasOnly(['analysis']);
          allow delete: if isOwner(userId);
        }
      }
    }
  }
}
