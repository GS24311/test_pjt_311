rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    // More permissive regex for general IDs, strict for UIDs
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name']) 
        && data.uid == request.auth.uid
        && data.name is string && data.name.size() <= 100
        && (!data.keys().contains('traitProfile') || data.traitProfile is map);
    }

    function isValidConversation(data) {
      return data.keys().hasAll(['userId', 'title', 'status'])
        && data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 600;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['role', 'content', 'senderName'])
        && data.role in ['user', 'partner']
        && data.content is string && data.content.size() <= 20000;
    }

    // Routes
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId); // Simplify updates to ownership check for reliability

      match /conversations/{conversationId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidConversation(incoming());
        allow update: if isOwner(userId); // Simplify updates to ownership check
        allow delete: if isOwner(userId);

        match /messages/{messageId} {
          allow list, get: if isOwner(userId);
          allow create: if isOwner(userId) && isValidMessage(incoming());
          allow update: if isOwner(userId); // Simplify updates to ownership check
          allow delete: if isOwner(userId);
        }
      }
    }
  }
}
