rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    // More permissive regex for general IDs, strict for UIDs
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name']) 
        && data.uid == request.auth.uid
        && data.name is string && data.name.size() <= 100
        && (!data.keys().contains('email') || data.email == null || (data.email is string && data.email.size() <= 256))
        && (!data.keys().contains('createdAt') || data.createdAt == request.time || data.createdAt is timestamp)
        && (!data.keys().contains('lastLoginAt') || data.lastLoginAt == request.time || data.lastLoginAt is timestamp)
        // Allow optional profile fields
        && (!data.keys().contains('traitProfile') || data.traitProfile is map)
        && (!data.keys().contains('settings') || data.settings is map);
    }

    function isValidConversation(data) {
      return data.keys().hasAll(['userId', 'title', 'status'])
        && data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 500
        && data.status in ['active', 'resolved']
        && (!data.keys().contains('createdAt') || data.createdAt == request.time || data.createdAt is timestamp)
        && (!data.keys().contains('lastMessageAt') || data.lastMessageAt == request.time || data.lastMessageAt is timestamp);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['role', 'content', 'senderName'])
        && data.role in ['user', 'partner']
        && data.content is string && data.content.size() <= 20000
        && data.senderName is string && data.senderName.size() <= 100
        && (!data.keys().contains('order') || data.order is int || data.order is float)
        && (!data.keys().contains('createdAt') || data.createdAt == request.time || data.createdAt is timestamp)
        && (!data.keys().contains('analysis') || data.analysis is map);
    }

    // Routes
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'traitProfile', 'settings', 'email', 'lastLoginAt']);

      match /conversations/{conversationId} {
        allow list, get: if isOwner(userId) && isValidId(userId);
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(conversationId) && isValidConversation(incoming());
        allow update: if isOwner(userId) && isValidId(userId) && isValidId(conversationId)
          && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'status', 'lastMessageAt']);
        allow delete: if isOwner(userId) && isValidId(userId) && isValidId(conversationId);

        match /messages/{messageId} {
          allow list, get: if isOwner(userId) && isValidId(userId);
          allow create: if isOwner(userId) && isValidId(userId) && isValidId(messageId) && isValidMessage(incoming());
          allow update: if isOwner(userId) && isValidId(userId) && isValidId(messageId) && isValidMessage(incoming())
            && incoming().diff(existing()).affectedKeys().hasOnly(['analysis']);
          allow delete: if isOwner(userId) && isValidId(userId) && isValidId(messageId);
        }
      }
    }
  }
}
